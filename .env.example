# ── eToro API credentials ─────────────────────────────────────────────────────
ETORO_MODE=demo                         # demo | real
ETORO_PUBLIC_API_KEY=                   # x-api-key header
ETORO_USER_KEY=                         # x-user-key header (JWT)

# ── Universe ──────────────────────────────────────────────────────────────────
# Crypto excluded by default: eToro's fee structure (1% spread/side + weekend-
# tripled overnight carry) made it unprofitable in backtesting regardless of
# leverage. See src/backtest/ for the full analysis.
WATCH_REGIONS=US,EU,ASIA,HONGKONG       # regions to scan

# ── Risk management ───────────────────────────────────────────────────────────
# Position sizing is risk-based (ATR stop distance), matching the validated
# backtest exactly (src/backtest/engine.py BacktestConfig defaults). Do not
# change these without re-running the backtest — they're not arbitrary knobs.
DAILY_LOSS_LIMIT_PCT=3.0                # block trading if daily loss exceeds this % of balance
RISK_PER_TRADE_PCT=1.0                  # % of balance risked per trade (at stop distance)
MAX_POSITION_SIZE_PCT=10.0              # notional cap as % of balance (before leverage)
LEVERAGE=1.0                            # real CFD leverage on the notional cap above
MAX_OPEN_POSITIONS=3                    # max simultaneous open positions
MIN_SIGNAL_CONFIDENCE=0.65              # minimum thesis confidence (0.0-1.0)
MIN_SIGNALS_REQUIRED=2                  # minimum signals cited in thesis

# ── Swing trading parameters ──────────────────────────────────────────────────
SWING_MIN_HORIZON_DAYS=5                # minimum thesis horizon_days
SWING_MAX_HORIZON_DAYS=20               # maximum thesis horizon_days
SWING_HARD_EXIT_DAYS=20                 # force-close after N days

# ── Screening thresholds ──────────────────────────────────────────────────────
# Trend-following: EMA50>EMA200 gate + Donchian breakout / EMA20 pullback-resume,
# both volume-confirmed. See src/agents/screening_agent.py.
SCREEN_REL_VOL=1.5                      # relative volume multiplier threshold
SCREEN_DONCHIAN_LOOKBACK=20             # breakout lookback in bars

# ── Telegram notifications ─────────────────────────────────────────────────────
TELEGRAM_TOKEN=                         # BotFather token
TELEGRAM_CHAT_ID=                       # your chat/group ID
