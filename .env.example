# eToro API credentials
ETORO_MODE=demo                     # demo | real
ETORO_PUBLIC_API_KEY=               # x-api-key header
ETORO_USER_KEY=                     # x-user-key header (JWT)

# Symbols to watch (comma-separated)
WATCH_SYMBOLS=BTC,ETH,AAPL,TSLA

# LLM configuration (used by SignalAgent and SentimentAgent)
# --- Option A: LM Studio (local, PC con RTX) ---
LLM_MODEL=lm_studio/qwen3-8b       # nombre del modelo cargado en LM Studio
LLM_BASE_URL=http://localhost:1234/v1
LLM_API_KEY=lm-studio               # cualquier string no vacío
# --- Option B: OpenAI ---
# LLM_MODEL=gpt-4o
# LLM_BASE_URL=
# LLM_API_KEY=sk-...
# --- Option C: Anthropic ---
# LLM_MODEL=claude-opus-4-8
# LLM_BASE_URL=
# LLM_API_KEY=sk-ant-...
# --- Option D: Ollama (local) ---
# LLM_MODEL=ollama/qwen3:8b
# LLM_BASE_URL=http://localhost:11434
# LLM_API_KEY=ollama

# Risk management
DAILY_LOSS_LIMIT_PCT=3.0            # block trading if daily loss exceeds this % of balance
MAX_POSITION_SIZE_PCT=2.0           # max % of balance per trade
MAX_OPEN_POSITIONS=3                # max simultaneous open positions

# Scheduler intervals (minutes)
MAIN_INTERVAL_MINUTES=15            # how often the main cycle runs
TRAILING_STOP_INTERVAL_MINUTES=5    # how often trailing stops are adjusted

# Telegram notifications
TELEGRAM_TOKEN=                     # BotFather token
TELEGRAM_CHAT_ID=                   # your chat/group ID

# NewsAPI (https://newsapi.org)
NEWS_API_KEY=

# Reddit (https://www.reddit.com/prefs/apps)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=etoroAgent/1.0
