# ── eToro API credentials ─────────────────────────────────────────────────────
ETORO_MODE=demo                         # demo | real
ETORO_PUBLIC_API_KEY=                   # x-api-key header
ETORO_USER_KEY=                         # x-user-key header (JWT)

# ── Universe ──────────────────────────────────────────────────────────────────
# Crypto excluded by default: eToro's fee structure (1% spread/side + weekend-
# tripled overnight carry) made it unprofitable in backtesting regardless of
# leverage. See src/backtest/ for the full analysis.
# JAPAN (genuine Tokyo Stock Exchange listings) has NOT been backtest-validated
# — eToro only added Japan in Q1 2026, so daily history is ~67 bars (need 250+).
# Included by explicit request; treat with extra caution vs the other regions.
# GERMANY/FRANCE/SWITZERLAND/AUSTRALIA/SWEDEN/UK: discovered via eToro's bulk
# instruments endpoint, backtest-validated (250+ bars each). See src/core/
# market_calendar.py for per-region trading hours.
WATCH_REGIONS=US,EU,ASIA,HONGKONG,JAPAN,GERMANY,FRANCE,SWITZERLAND,AUSTRALIA,SWEDEN,UK # regions to scan

# ── Risk management ───────────────────────────────────────────────────────────
# Position sizing is risk-based (ATR stop distance), matching the validated
# PORTFOLIO backtest exactly (src/backtest/portfolio_engine.py — shared equity,
# 3 max positions, 2-per-sector cap, conviction priority queueing;
# atr_stop_multiple=2.5 in src/agents/thesis_builder.py). Do not change these
# without re-running the backtest — they're not arbitrary knobs. Validated:
# OOS PF 2.77, P&L $2,291.20 on $800, drawdown 38.38%.
DAILY_LOSS_LIMIT_PCT=3.0                # block trading if daily loss exceeds this % of balance
RISK_PER_TRADE_PCT=15.0                 # % of balance risked per trade (at stop distance)
MAX_POSITION_SIZE_PCT=10.0              # notional cap as % of balance (before leverage)
LEVERAGE=3.0                            # real CFD leverage on the notional cap above
MAX_OPEN_POSITIONS=3                    # max simultaneous open positions (backtest-validated ceiling —
                                         # every higher value tested (4/5/6/8/10) broke out-of-sample)
MIN_SIGNAL_CONFIDENCE=0.65              # minimum thesis confidence (0.0-1.0)
MIN_SIGNALS_REQUIRED=2                  # minimum signals cited in thesis
MAX_POSITIONS_PER_SECTOR=2              # caps correlated exposure (e.g. no more than 2 banks at once)

# Account drawdown hard stop — separate from DAILY_LOSS_LIMIT_PCT (which only
# blocks trading for the rest of the current day). Tracks drawdown from the
# account's all-time-high balance and throttles risk-per-trade down to
# REDUCED_RISK_PCT once crossed, until the account recovers above that line.
# 20% was found to be the sweet spot — 10%/15% throttled too often and gave
# up upside; disabling it entirely let drawdown run past 55%.
ACCOUNT_DRAWDOWN_HARD_STOP_PCT=20.0     # % drawdown from peak balance that triggers the throttle
REDUCED_RISK_PCT=3.0                    # risk-per-trade used while the throttle is active

# ── Swing trading parameters ──────────────────────────────────────────────────
SWING_MIN_HORIZON_DAYS=5                # minimum thesis horizon_days
SWING_MAX_HORIZON_DAYS=20               # maximum thesis horizon_days
SWING_HARD_EXIT_DAYS=20                 # force-close after N days

# ── Screening thresholds ──────────────────────────────────────────────────────
# Trend-following: EMA50>EMA200 gate + Donchian breakout / EMA20 pullback-resume,
# both volume-confirmed. See src/agents/screening_agent.py.
SCREEN_REL_VOL=1.5                      # relative volume multiplier threshold
SCREEN_DONCHIAN_LOOKBACK=20             # breakout lookback in bars

# ── Telegram notifications ─────────────────────────────────────────────────────
TELEGRAM_TOKEN=                         # BotFather token
TELEGRAM_CHAT_ID=                       # your chat/group ID
