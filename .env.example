# ── eToro API credentials ─────────────────────────────────────────────────────
ETORO_MODE=demo                         # demo | real
ETORO_PUBLIC_API_KEY=                   # x-api-key header
ETORO_USER_KEY=                         # x-user-key header (JWT)

# ── LLM (OpenAI-compatible endpoint — no LiteLLM) ─────────────────────────────
# The bot uses the openai Python SDK. Point it at any OpenAI-compatible server.
# Anthropic is NOT supported without adding LiteLLM as a dependency.

# Option A: LM Studio (local, recommended)
LLM_MODEL=deepseek-coder-v2-lite-instruct  # exact id from GET /v1/models
LLM_BASE_URL=http://localhost:1234/v1
LLM_API_KEY=lm-studio                      # any non-empty string

# Option B: OpenAI
# LLM_MODEL=gpt-4o
# LLM_BASE_URL=
# LLM_API_KEY=sk-...

# Option C: Ollama
# LLM_MODEL=qwen2.5-coder:7b
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_API_KEY=ollama

LLM_TEMPERATURE=0.3
LLM_MAX_ITERATIONS=8

# Optional: use a faster/cheaper model for the Stage 1b screening pass
# SCREENING_LLM_MODEL=deepseek-coder-v2-lite-instruct

# ── Universe ──────────────────────────────────────────────────────────────────
WATCH_REGIONS=US,EU,ASIA,CRYPTO         # regions to scan

# ── Risk management ───────────────────────────────────────────────────────────
DAILY_LOSS_LIMIT_PCT=3.0                # block trading if daily loss exceeds this % of balance
MAX_POSITION_SIZE_PCT=2.0               # max % of balance per trade
MAX_OPEN_POSITIONS=3                    # max simultaneous open positions
MIN_SIGNAL_CONFIDENCE=0.65              # minimum thesis confidence (0.0-1.0)
MIN_SIGNALS_REQUIRED=2                  # minimum MCP tools cited in thesis

# ── Swing trading parameters ──────────────────────────────────────────────────
SWING_MIN_HORIZON_DAYS=5                # minimum thesis horizon_days
SWING_MAX_HORIZON_DAYS=20               # maximum thesis horizon_days
SWING_HARD_EXIT_DAYS=20                 # force-close after N days (no LLM)

# ── Screening thresholds (Stage 1a) ───────────────────────────────────────────
SCREEN_RSI_OVERSOLD=35
SCREEN_RSI_OVERBOUGHT=65
SCREEN_REL_VOL=1.5                      # relative volume multiplier threshold
SCREEN_EMA_CROSS_DAYS=3                 # look-back days for EMA20/50 crossover

# ── Position review ───────────────────────────────────────────────────────────
REVIEW_MIN_CONFIDENCE=0.55

# ── Telegram notifications ─────────────────────────────────────────────────────
TELEGRAM_TOKEN=                         # BotFather token
TELEGRAM_CHAT_ID=                       # your chat/group ID

# ── Data providers ────────────────────────────────────────────────────────────
FINNHUB_API_KEY=                        # https://finnhub.io — free tier: 60 req/min
CRYPTOPANIC_API_KEY=                    # https://cryptopanic.com/api — free tier

# Reddit (https://www.reddit.com/prefs/apps -> create "script" app)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=etoroAgent/1.0
